// Prestige AI — Windows Launcher Resource
// Embeds the app icon into the .exe
IDI_ICON1 ICON "..\\resources\\prestige.ico"

1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEOS 0x40004
FILETYPE 0x1
{
    BLOCK "StringFileInfo"
    {
        BLOCK "040904B0"
        {
            VALUE "CompanyName", "Prestige Technologie Company"
            VALUE "FileDescription", "Prestige AI — Broadcast Overlay System"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "PrestigeAI"
            VALUE "LegalCopyright", "© 2024-2026 Prestige Technologie Company"
            VALUE "OriginalFilename", "PrestigeAI.exe"
            VALUE "ProductName", "Prestige AI"
            VALUE "ProductVersion", "1.0.0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0409, 1200
    }
}
